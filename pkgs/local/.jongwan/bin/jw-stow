#!/usr/bin/env bash
set -euo pipefail

# 인자로 전달한 패키지들을 HOME 폴더에 설치한다.
# 패키지는 이 저장소의 pkgs/<pkg> 경로에 위치한다.
#
# 패키지는 다음과 같은 종류의 파일들로 구성된다.
# - 저장소와 동기화되는 파일 (심링크로 설치)
#   - 모든 플랫폼에서 공통으로 쓰이는 파일
#   - 특정 플랫폼에서만 쓰이는 파일 (파일명에 .darwin, .linux 같은 토큰을 붙임)
# - 저장소와 동기화되지 않는 파일 (복사로 설치, .skel 로 끝나는 파일, 초기 설정 제공용)
#
# ✅ 패키지 아래에 있는 파일들을 HOME 폴더에 동일한 파일 구조로 심링크한다.
# ✅ 플랫폼 전용 파일은 .darwin, .linux 같은 토큰을 파일명에 붙이는데,
# 다른 플랫폼 전용 파일은 심링크하지 않는다.
# (예: macOS에서 jw-stow mpv 를 실행하면 mpv.conf.darwin.zsh 는 심링크되지만
# mpv.conf.linux.zsh 는 심링크되지 않는다.)
# ✅ 스켈레톤 파일(.skel)은 심링크하지 않고, 타깃에 해당 파일이 없을 때만 복사해서 실제 파일로 만든다.
# 저장소 안의 내용과 동기화하지 않으면서 초기 설정을 제공하는 용도다.
#
# 심링크는 stow를 사용하여 수행한다. --no-folding 옵션으로 중간 디렉토리들을 실제로 만들고,
# 개별 파일들마다 심링크한다.
if [ "$#" -eq 0 ]; then
	echo "사용법: jw-stow <pkg> [<pkg> ...]" >&2
	exit 1
fi

# 이 스크립트 자신은 pkgs/local/.jongwan/bin/jw-stow 가 ~/.jongwan/bin/jw-stow 로 심링크되어
# 실행되므로, 심링크를 직접 풀어서 저장소 안의 실제 위치를 알아내야 pkgs_dir 을 찾을 수 있다.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
	link="$(readlink "$self")"
	case "$link" in
	/*) self="$link" ;;
	*) self="$(cd -P "$(dirname "$self")" &>/dev/null && pwd)/$link" ;;
	esac
done

pkgs_dir="$(cd -P "$(dirname "$self")/../../.." &>/dev/null && pwd)"

if ! command -v stow &>/dev/null; then
	echo "stow 명령을 찾을 수 없습니다. 먼저 설치해 주세요 (예: brew install stow)." >&2
	exit 1
fi

case "$(uname -s)" in
Darwin)
	other_os=linux
	;;
Linux)
	other_os=darwin
	;;
*)
	echo "지원하지 않는 OS 입니다: $(uname -s)" >&2
	exit 1
	;;
esac

for pkg in "$@"; do
	pkg_path="$pkgs_dir/$pkg/"
	target_path="$HOME"

	if [ ! -d "$pkg_path" ]; then
		echo "존재하지 않는 패키지입니다: $pkg ($pkg_path)" >&2
		exit 1
	fi

	# .darwin / .linux 같은 플랫폼 토큰은 파일명 끝(config.darwin)뿐 아니라 중간
	# (something.darwin.zsh), 구분자가 -/_ 인 경우(something-darwin, something_darwin.ext),
	# 심지어 디렉터리 이름 자체(darwin/... 또는 트리 중간의 sub/darwin/...)로도 올 수 있다.
	# stow --ignore 는 패키지 기준 상대 경로 전체(예: .zshrc.d/something.darwin.zsh)에 대해
	# 앵커 없이 매칭하므로, ^/$ 는 각 경로 컴포넌트가 아니라 그 상대 경로 문자열 전체의
	# 시작/끝이다. 트리 중간 디렉터리(sub/darwin/foo)까지 잡으려면 경로 구분자 /도 경계
	# 문자에 포함해야 한다.
	stow --dir="$pkgs_dir" --target="$target_path" --ignore="(^|[/._-])(${other_os})(\$|[/._-])|\\.skel\$" --no-folding --restow "$pkg"
	echo "설치됨: $pkg -> ~ (--no-folding)"

	#region: skeleton 파일(.skel) 처리
	# -d '' 는 \0(null) 문자를 구분자(delimiter)로 쓰겠다는 의미.
	# find의 -print0 과 조합하여 파일 이름에 공백이 있어도 안전하게 처리 가능.
	while IFS= read -r -d '' skel; do
		# pkg_path 뒤의 상대 경로 추출
		rel="${skel#"$pkg_path"}"
		# .skel 확장자를 제거하고 target_path 아래의 실제 경로 계산
		real="$target_path/${rel%.skel}"

		if [ ! -e "$real" ]; then
			mkdir -p "$(dirname "$real")"
			cp "$skel" "$real"
			echo "생성됨: $real ($pkg/$rel 에서 복사, 로컬에서 자유롭게 수정 가능)"
		fi
	done < <(find "$pkg_path" -type f -name '*.skel' -print0)
	#endregion

	#region: package 별 예외 처리
	# mpv 의 include 는 대상 파일이 없으면 에러를 낸다(git/tmux 의 -q 와 다름).
	# 따라서 mpv.conf 파일에서 include하는 모든 파일이 존재해야 한다.
	# local 파일은 skel 파일로 처리했고, platform 별 파일은 symlink가 걸리지 않은 파일의 경우,
	# 여기서 빈 파일을 생성해준다.
	if [ "$pkg" = "mpv" ]; then
		mpv_dir="$HOME/.config/mpv"
		mkdir -p "$mpv_dir"

		# touch는 기본적으로 access time과 modification time을 현재 시간으로 갱신하고,
		# 파일이 없으면 새로 생성한다.
		# -a 옵션을 쓰면, access time만 갱신하고 modification time은 그대로 둔다.
		for platform in darwin linux; do
			touch -a "$mpv_dir/mpv.$platform.conf"
		done
	fi
	#endregion
done
