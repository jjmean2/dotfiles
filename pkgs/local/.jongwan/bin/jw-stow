#!/usr/bin/env bash
set -euo pipefail

# 인자로 전달한 패키지들을 HOME 폴더에 설치한다.
# 패키지는 이 저장소의 pkgs/<pkg> 경로에 위치한다.
#
# 패키지는 다음과 같은 종류의 파일들로 구성된다.
# - 저장소와 동기화되는 파일 (심링크로 설치)
#   - 모든 플랫폼에서 공통으로 쓰이는 파일
#   - 특정 플랫폼에서만 쓰이는 파일 (파일 경로에 .darwin, .linux 같은 토큰을 포함)
# - 저장소와 동기화되지 않는 파일 (복사로 설치, .skel 로 끝나는 파일, 초기 설정 제공용)
#
# stow 명령으로 저장소와 동기화될 파일을 symlink로 설치하고,
# .skel 파일은 타겟 디렉토리에 없을 때만 복사하여 초기값으로 사용한다.
# -d 옵션은 stow로 설치한 symlink만 제거한다.

OTHER_OS=""
DELETE_MODE=0
PKGS_DIR=""
TARGET_DIR=""
PKGS=()
CREATED_FILES=()

parse_args() {
	local opt
	local OPTIND=1

	while getopts ":d" opt; do
		case "$opt" in
		d) DELETE_MODE=1 ;;
		*)
			echo "사용법: jw-stow [-d] <pkg> [<pkg> ...]" >&2
			return 1
			;;
		esac
	done
	shift $((OPTIND - 1))

	PKGS=("$@")

	if [[ ${#PKGS[@]} -eq 0 ]]; then
		echo "사용법: jw-stow [-d] <pkg> [<pkg> ...]" >&2
		return 1
	fi
}

_init_env_other_os() {
	case "$(uname -s)" in
	Darwin) OTHER_OS=linux ;;
	Linux) OTHER_OS=darwin ;;
	*)
		echo "지원하지 않는 OS 입니다: $(uname -s)" >&2
		return 1
		;;
	esac
}

_init_env_directories() {
	local self link
	# 이 스크립트 자신은 pkgs/local/.jongwan/bin/jw-stow 가 ~/.jongwan/bin/jw-stow 로 심링크되어
	# 실행되므로, 심링크를 직접 풀어서 저장소 안의 실제 위치를 알아내야 PKGS_DIR 을 찾을 수 있다.
	self="${BASH_SOURCE[0]}"
	while [ -L "$self" ]; do
		link="$(readlink "$self")"
		case "$link" in
		/*) self="$link" ;;
		*) self="$(cd -P "$(dirname "$self")" &>/dev/null && pwd)/$link" ;;
		esac
	done

	PKGS_DIR="$(cd -P "$(dirname "$self")/../../.." &>/dev/null && pwd)"
	TARGET_DIR="$HOME"
}

init_env() {
	if ! command -v stow &>/dev/null; then
		echo "stow 명령을 찾을 수 없습니다. 먼저 설치해 주세요 (예: brew install stow)." >&2
		return 1
	fi

	_init_env_other_os || return 1
	_init_env_directories || return 1

}

stow_with_opts() {
	local opts=(
		-v
		--dir="$PKGS_DIR"
		--target="$TARGET_DIR"
		--no-folding
		--ignore='\.skel'
		--ignore='(?:.*[._-])?'"${OTHER_OS}"'(?:[._-].*)?'
	)
	stow "${opts[@]}" "$@"
}

copy_skel_files() {
	local skel target

	# -d '' 는 \0(null) 문자를 구분자(delimiter)로 쓰겠다는 의미.
	# find의 -print0 과 조합하여 파일 이름에 공백이 있어도 안전하게 처리 가능.
	while IFS= read -r -d '' skel; do
		# 패키지 디렉토리로부터의 상대 경로 추출
		target="${skel#"$PKGS_DIR"/*/}"
		# .skel 확장자 제거 후, 타겟 디렉토리 아래의 경로 계산
		target="$TARGET_DIR/${target%.skel}"

		if [[ -e "$target" ]]; then
			echo "스켈레톤 파일 건너뜀: $target (이미 존재함)" >&2
			continue
		fi

		mkdir -p "$(dirname "$target")" || return 1
		cp "$skel" "$target" || return 1

		CREATED_FILES+=("$target")
		echo "생성됨: $target ($skel 에서 복사, 로컬에서 자유롭게 수정 가능)"
	done < <(find "${PKGS[@]/#/$PKGS_DIR/}" -type f -name '*.skel' -print0)
}

rollback() {
	# 1. 롤백할 파일이 없으면 즉시 종료
	if [[ ${#CREATED_FILES[@]} -eq 0 ]]; then
		return
	fi

	printf -- "\n%s\n\n" "에러 발생! 다음 파일들을 삭제하고 원상 복구할 수 있습니다:"
	printf -- "  - %s\n" "${CREATED_FILES[@]}"
	printf -- "\n"

	if [[ -t 0 ]]; then
		local answer
		read -r -p "위 파일들을 삭제하고 원상 복구하시겠습니까? (y/N): " answer </dev/tty

		if [[ ! $answer =~ ^[yY]$ ]]; then
			echo "⚠️ 롤백을 취소했습니다."
			return 1
		fi
	fi

	echo "🧹 원상 복구를 진행합니다..."
	for file in "${CREATED_FILES[@]}"; do
		if [[ -f "$file" ]]; then
			rm -f "$file"
			echo "삭제됨: $file"
		fi
	done

	echo "롤백 완료"
	return
}

run_pkg_post_install_script() {
	local pkg
	for pkg in "${PKGS[@]}"; do

		case "$pkg" in
		mpv)
			# mpv 설정 디렉토리 생성
			local mpv_dir="$HOME/.config/mpv"
			if ! mkdir -p "$mpv_dir"; then
				echo "mpv 설정 디렉토리 생성 실패: $mpv_dir" >&2
				return 1
			fi

			# touch는 기본적으로 access time과 modification time을 현재 시간으로 갱신하고,
			# 파일이 없으면 새로 생성한다.
			# -a 옵션을 쓰면, access time만 갱신하고 modification time은 그대로 둔다.
			local platform
			for platform in darwin linux; do
				if ! touch -a "$mpv_dir/mpv.$platform.conf"; then
					echo "mpv 설정 파일 생성 실패: $mpv_dir/mpv.$platform.conf" >&2
					return 1
				fi
			done
			;;

		*)
			;;
		esac
	done
}

main() {
	parse_args "$@" || return 1
	init_env || return 1

	if [[ $DELETE_MODE -eq 1 ]]; then
		stow_with_opts --delete "${PKGS[@]}"
		return
	fi

	stow_with_opts --restow "${PKGS[@]}"
	if ! copy_skel_files; then
		rollback
		return 1
	fi

	run_pkg_post_install_script
}

main "$@"
