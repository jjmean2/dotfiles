#!/usr/bin/env bash
set -euo pipefail

# pkgs/<pkg>/ 를 하나씩 ~ 에 stow 로 설치한다. scripts/install_pkgs.sh 가 모든 패키지에 대해
# 이 스크립트를 반복 호출하고, 패키지 하나만 다시 설치하고 싶을 때 직접 실행해도 된다.
# --no-folding 으로 설치해서, 여러 패키지가 같은 하위 디렉토리(예: ~/.jongwan, ~/.config/git)를
# 나눠 써도 서로 충돌하지 않는다.
# - 현재 OS 와 반대되는 플랫폼 전용 파일(*.darwin / *.linux)은 심링크를 만들지 않는다.
# - <name>.skel 파일은 심링크로 두지 않는다. 대신 타깃에 <name> 파일이 아직 없을 때만
#   한 번 복사해서 실제 파일로 만들어 둔다.
#
# 사용법: jw-stow <pkg> [<pkg> ...]

if [ "$#" -eq 0 ]; then
	echo "사용법: jw-stow <pkg> [<pkg> ...]" >&2
	exit 1
fi

# 이 스크립트 자신은 pkgs/local/.jongwan/bin/jw-stow 가 ~/.jongwan/bin/jw-stow 로 심링크되어
# 실행되므로, 심링크를 직접 풀어서 저장소 안의 실제 위치를 알아내야 pkgs_dir 을 찾을 수 있다.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
	link="$(readlink "$self")"
	case "$link" in
	/*) self="$link" ;;
	*) self="$(cd "$(dirname "$self")" &>/dev/null && pwd)/$link" ;;
	esac
done

pkgs_dir="$(cd "$(dirname "$self")/../../.." &>/dev/null && pwd)"

if ! command -v stow &>/dev/null; then
	echo "stow 명령을 찾을 수 없습니다. 먼저 설치해 주세요 (예: brew install stow)." >&2
	exit 1
fi

case "$(uname -s)" in
Darwin) other_os=linux ;;
Linux) other_os=darwin ;;
*)
	echo "지원하지 않는 OS 입니다: $(uname -s)" >&2
	exit 1
	;;
esac

for pkg in "$@"; do
	pkg_path="$pkgs_dir/$pkg/"

	if [ ! -d "$pkg_path" ]; then
		echo "존재하지 않는 패키지입니다: $pkg ($pkg_path)" >&2
		exit 1
	fi

	stow --dir="$pkgs_dir" --target="$HOME" --ignore="\\.(${other_os}|skel)\$" --no-folding --restow "$pkg"
	echo "설치됨: $pkg -> ~ (--no-folding)"

	# -d '' 는 \0(null) 문자를 구분자(delimiter)로 쓰겠다는 의미. 파일 이름에 공백이 있어도 안전하게 처리 가능.
	while IFS= read -r -d '' skel; do
		rel="${skel#"$pkg_path"}"
		real="$HOME/${rel%.skel}"

		if [ ! -e "$real" ]; then
			mkdir -p "$(dirname "$real")"
			cp "$skel" "$real"
			echo "생성됨: $real ($pkg/$rel 에서 복사, 로컬에서 자유롭게 수정 가능)"
		fi
	done < <(find "$pkg_path" -type f -name '*.skel' -print0)
done
